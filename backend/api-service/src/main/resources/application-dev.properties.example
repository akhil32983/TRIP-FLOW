# API Service - Development Configuration

# This is a template file. Copy it to application-dev.properties and add your real secrets
# application-dev.properties is in .gitignore and won't be committed

# JWT Configuration
jwt.secret=your-jwt-secret-here

# Unsplash API Configuration
unsplash.api.key=your-unsplash-api-key

# Admin User Configuration
admin.username=your-admin-username
admin.password=your-admin-password