# AI Service - Development Configuration

# This is a template file. Copy it to application-dev.properties and add your real secrets
# application-dev.properties is in .gitignore and won't be committed

# AI Configuration (OpenAI or compatible API)
ai.api.key=sk-your-openai-api-key-here
ai.api.url=https://api.openai.com/v1
ai.api.model=gpt-4o-mini

# JWT Configuration
jwt.secret=your-jwt-secret-here