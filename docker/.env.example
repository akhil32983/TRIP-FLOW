# Database Configuration
POSTGRES_DB=tripflow_db
POSTGRES_USER=tripflow_user
POSTGRES_PASSWORD=secure_password

# API Service Secrets
JWT_SECRET=your_jwt_secret_here
UNSPLASH_API_KEY=your_unsplash_api_key
ADMIN_EMAIL=admin@tripflow.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_secure_password

# AI Service Secrets
AI_API_KEY=your_ai_api_key
AI_API_URL=https://api.openai.com
AI_API_MODEL=gpt-4o-mini

# Notification Service Secrets
EMAIL_SENDER=noreply@tripflow.com
EMAIL_BREVO_API_KEY=your_brevo_api_key
